[model-availability cap:in="media:model-spec;textable";op=model-availability;out="media:model-availability;textable;record"]
[model-status cap:in="media:model-spec;textable";op=model-status;out="media:model-status;textable;record"]
[generate_thumbnail cap:in=media:pdf;op=render_page_image;out="media:image;png"]
[describe_image cap:candle;in="media:image;png";ml-model;op=describe_image;out="media:image-description;textable"]
[generate_embeddings cap:candle;in="media:textable";ml-model;op=generate_embeddings;out="media:embedding-vector;textable;record"]
[model_spec -> model-availability -> availability]
[model_spec -> model-status -> status]
[pdf_input -> generate_thumbnail -> thumbnail]
[thumbnail -> describe_image -> description]
[description -> generate_embeddings -> embedding]
