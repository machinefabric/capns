[generate_thumbnail_txt cap:in="media:txt;textable";op=render_page_image;out="media:image;png"]
[generate_image_embeddings_txt cap:candle;in="media:image;png";ml-model;op=generate_image_embeddings;out="media:embedding-vector;textable;record"]
[generate_thumbnail_md cap:in="media:md;textable";op=render_page_image;out="media:image;png"]
[generate_image_embeddings_md cap:candle;in="media:image;png";ml-model;op=generate_image_embeddings;out="media:embedding-vector;textable;record"]
[generate_thumbnail_rst cap:in="media:rst;textable";op=render_page_image;out="media:image;png"]
[generate_image_embeddings_rst cap:candle;in="media:image;png";ml-model;op=generate_image_embeddings;out="media:embedding-vector;textable;record"]
[generate_thumbnail_log cap:in="media:log;textable";op=render_page_image;out="media:image;png"]
[generate_image_embeddings_log cap:candle;in="media:image;png";ml-model;op=generate_image_embeddings;out="media:embedding-vector;textable;record"]
[txt_input -> generate_thumbnail_txt -> txt_thumbnail]
[txt_thumbnail -> generate_image_embeddings_txt -> txt_img_embed]
[md_input -> generate_thumbnail_md -> md_thumbnail]
[md_thumbnail -> generate_image_embeddings_md -> md_img_embed]
[rst_input -> generate_thumbnail_rst -> rst_thumbnail]
[rst_thumbnail -> generate_image_embeddings_rst -> rst_img_embed]
[log_input -> generate_thumbnail_log -> log_thumbnail]
[log_thumbnail -> generate_image_embeddings_log -> log_img_embed]
