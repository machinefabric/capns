    digraph three_cartridge_pipeline {
        model_spec -> availability [label="cap:in=\"media:model-spec;textable\";op=model-availability;out=\"media:model-availability;textable;record\""];
        model_spec -> status [label="cap:in=\"media:model-spec;textable\";op=model-status;out=\"media:model-status;textable;record\""];
        pdf_input -> pdf_metadata [label="cap:in=media:pdf;op=extract_metadata;out=\"media:file-metadata;textable;record\""];
        pdf_input -> pdf_thumbnail [label="cap:in=media:pdf;op=generate_thumbnail;out=\"media:image;png;thumbnail\""];
        md_input -> md_metadata [label="cap:in=\"media:md;textable\";op=extract_metadata;out=\"media:file-metadata;textable;record\""];
        md_input -> md_thumbnail [label="cap:in=\"media:md;textable\";op=generate_thumbnail;out=\"media:image;png;thumbnail\""];
    }
