    digraph pdf_thumbnail_describe_embed_chain {
        pdf_input -> thumbnail [label="cap:in=media:pdf;op=generate_thumbnail;out=\"media:image;png;thumbnail\""];
        thumbnail -> description [label="cap:candle;in=\"media:image;png\";ml-model;op=describe_image;out=\"media:image-description;textable\""];
        description -> embedding [label="cap:candle;in=\"media:textable\";ml-model;op=generate_embeddings;out=\"media:embedding-vector;textable;record\""];
    }