[extract_metadata cap:in=media:pdf;op=extract_metadata;out="media:file-metadata;textable;record"]
[generate_thumbnail cap:in=media:pdf;op=generate_thumbnail;out="media:image;png;thumbnail"]
[describe_image cap:candle;in="media:image;png";ml-model;op=describe_image;out="media:image-description;textable"]
[generate_embeddings cap:candle;in="media:textable";ml-model;op=generate_embeddings;out="media:embedding-vector;textable;record"]
[generate_image_embeddings cap:candle;in="media:image;png";ml-model;op=generate_image_embeddings;out="media:embedding-vector;textable;record"]
[pdf_input -> extract_metadata -> metadata]
[pdf_input -> generate_thumbnail -> thumbnail]
[thumbnail -> describe_image -> description]
[description -> generate_embeddings -> desc_embedding]
[thumbnail -> generate_image_embeddings -> img_embedding]
