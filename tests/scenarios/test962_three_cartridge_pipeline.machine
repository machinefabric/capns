[model-availability cap:in="media:model-spec;textable";op=model-availability;out="media:model-availability;textable;record"]
[model-status cap:in="media:model-spec;textable";op=model-status;out="media:model-status;textable;record"]
[extract_metadata_pdf cap:in=media:pdf;op=extract_metadata;out="media:file-metadata;textable;record"]
[generate_thumbnail_pdf cap:in=media:pdf;op=generate_thumbnail;out="media:image;png;thumbnail"]
[extract_metadata_md cap:in="media:md;textable";op=extract_metadata;out="media:file-metadata;textable;record"]
[generate_thumbnail_md cap:in="media:md;textable";op=generate_thumbnail;out="media:image;png;thumbnail"]
[model_spec -> model-availability -> availability]
[model_spec -> model-status -> status]
[pdf_input -> extract_metadata_pdf -> pdf_metadata]
[pdf_input -> generate_thumbnail_pdf -> pdf_thumbnail]
[md_input -> extract_metadata_md -> md_metadata]
[md_input -> generate_thumbnail_md -> md_thumbnail]
