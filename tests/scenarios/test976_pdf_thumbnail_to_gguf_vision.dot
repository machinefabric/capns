    digraph pdf_thumbnail_to_gguf_vision {
        model_spec [media="media:model-spec;textable"];
        pdf_input -> thumbnail [label="cap:in=media:pdf;op=generate_thumbnail;out=\"media:image;png;thumbnail\""];
        thumbnail -> analysis [label="cap:gguf;in=\"media:image;png\";ml-model;op=describe_image;out=\"media:image-description;textable\";vision"];
        model_spec -> analysis [label="cap:gguf;in=\"media:image;png\";ml-model;op=describe_image;out=\"media:image-description;textable\";vision"];
    }
