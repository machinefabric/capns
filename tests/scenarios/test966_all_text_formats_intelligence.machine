[generate_thumbnail_txt cap:in="media:txt;textable";op=generate_thumbnail;out="media:image;png;thumbnail"]
[extract_metadata_rst cap:in="media:rst;textable";op=extract_metadata;out="media:file-metadata;textable;record"]
[extract_outline_rst cap:in="media:rst;textable";op=extract_outline;out="media:document-outline;textable;record"]
[generate_thumbnail_rst cap:in="media:rst;textable";op=generate_thumbnail;out="media:image;png;thumbnail"]
[extract_metadata_log cap:in="media:log;textable";op=extract_metadata;out="media:file-metadata;textable;record"]
